rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocumentPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userDocumentPath());
    }

    function currentUser() {
      return get(userDocumentPath()).data;
    }

    function isSeller() {
      return hasUserProfile() && currentUser().role == 'seller';
    }

    function isSupervisor() {
      return hasUserProfile() && currentUser().role == 'supervisor';
    }

    function isAdmin() {
      return hasUserProfile() && currentUser().role == 'admin';
    }

    function hasSameBranch(branchId) {
      return hasUserProfile() && currentUser().branchId == branchId;
    }

    function canReadBranch(branchId) {
      return isAdmin() || hasSameBranch(branchId);
    }

    function canReadInventory(branchId) {
      return hasUserProfile() && (isAdmin() || hasSameBranch(branchId) || isSeller() || isSupervisor());
    }

    function canCreateOwnSuccessfulSyncLog(data) {
      return isSupervisor()
        && data.branchId is string
        && hasSameBranch(data.branchId)
        && data.branchName is string
        && data.type == 'inventory'
        && (data.status == 'success' || data.status == 'completed' || data.status == 'ok')
        && data.recordsProcessed is int;
    }

    function canManageInventory(branchId) {
      return isAdmin() || (isSupervisor() && hasSameBranch(branchId));
    }

    function canHandleReservation(branchId) {
      return isAdmin() || ((isSeller() || isSupervisor()) && hasSameBranch(branchId));
    }

    function canApproveReservation(branchId) {
      return isAdmin() || (isSupervisor() && hasSameBranch(branchId));
    }

    function canReadReservation(data) {
      return isAdmin()
        || canReadBranch(data.branchId)
        || (data.requestingBranchId is string && hasSameBranch(data.requestingBranchId))
        || (signedIn() && data.reservedBy == request.auth.uid);
    }

    function canUpdateReservation(data) {
      return isAdmin()
        || canHandleReservation(data.branchId)
        || (signedIn() && data.reservedBy == request.auth.uid);
    }

    function canRequestTransfer(branchId) {
      return isAdmin() || ((isSeller() || isSupervisor()) && hasSameBranch(branchId));
    }

    function canApproveTransfer(branchId) {
      return isAdmin() || (isSupervisor() && hasSameBranch(branchId));
    }

    function canDispatchTransfer(branchId) {
      return isAdmin() || (isSupervisor() && hasSameBranch(branchId));
    }

    function canReceiveTransfer(branchId) {
      return isAdmin() || ((isSeller() || isSupervisor()) && hasSameBranch(branchId));
    }

    function canRegisterSale(branchId) {
      return isAdmin() || ((isSeller() || isSupervisor()) && hasSameBranch(branchId));
    }

    function canReadSale(data) {
      return isAdmin()
        || (isSupervisor() && hasSameBranch(data.branchId))
        || (signedIn() && data.sellerId == request.auth.uid);
    }

    function validInventoryDerivedFields(data) {
      return data.availableStock == data.stock - data.reservedStock
        && data.isLowStock == (data.availableStock <= data.minimumStock)
        && data.updatedBy == request.auth.uid;
    }

    function sameInventoryCatalogScope(data, existing) {
      return data.branchId == existing.branchId
        && data.branchName == existing.branchName
        && data.productId == existing.productId
        && data.productName == existing.productName
        && data.sku == existing.sku
        && data.minimumStock == existing.minimumStock
        && data.isActive == existing.isActive
        && data.lastSyncAt == existing.lastSyncAt;
    }

    function canRecordIncomingTransferInventory(data, existing) {
      return isSupervisor()
        && sameInventoryCatalogScope(data, existing)
        && data.stock == existing.stock
        && data.reservedStock == existing.reservedStock
        && data.availableStock == existing.availableStock
        && data.incomingStock > existing.incomingStock;
    }

    function canCreateIncomingTransferInventory(data) {
      return isSupervisor()
        && data.branchId is string
        && data.branchName is string
        && data.productId is string
        && data.productName is string
        && data.sku is string
        && data.stock == 0
        && data.reservedStock == 0
        && data.availableStock == 0
        && data.incomingStock > 0
        && data.minimumStock == 0
        && data.isActive == true;
    }

    function canReceiveIncomingTransferInventory(data, existing) {
      return (isSeller() || isSupervisor())
        && hasSameBranch(existing.branchId)
        && sameInventoryCatalogScope(data, existing)
        && data.reservedStock == existing.reservedStock
        && data.stock > existing.stock
        && data.incomingStock < existing.incomingStock
        && data.stock - existing.stock == existing.incomingStock - data.incomingStock;
    }

    function canRegisterSaleInventory(data, existing) {
      return (isSeller() || isSupervisor())
        && hasSameBranch(existing.branchId)
        && sameInventoryCatalogScope(data, existing)
        && data.reservedStock == existing.reservedStock
        && data.incomingStock == existing.incomingStock
        && data.stock < existing.stock;
    }

    function sameTransferScope(data, existing) {
      return data.productId == existing.productId
        && data.productName == existing.productName
        && data.sku == existing.sku
        && data.fromBranchId == existing.fromBranchId
        && data.fromBranchName == existing.fromBranchName
        && data.toBranchId == existing.toBranchId
        && data.toBranchName == existing.toBranchName
        && data.requestedBy == existing.requestedBy
        && data.requestedByName == existing.requestedByName
        && data.quantity == existing.quantity
        && data.reason == existing.reason
        && data.notes == existing.notes;
    }

    function sameReservationScope(data, existing) {
      return data.productId == existing.productId
        && data.productName == existing.productName
        && data.sku == existing.sku
        && data.branchId == existing.branchId
        && data.branchName == existing.branchName
        && data.requestingBranchId == existing.requestingBranchId
        && data.requestingBranchName == existing.requestingBranchName
        && data.customerName == existing.customerName
        && data.customerPhone == existing.customerPhone
        && data.quantity == existing.quantity
        && data.reservedBy == existing.reservedBy
        && data.requestedByName == existing.requestedByName
        && data.expiresAt == existing.expiresAt
        && data.createdAt == existing.createdAt;
    }

    function sameNotificationScope(data, existing) {
      return data.userId == existing.userId
        && data.title == existing.title
        && data.message == existing.message
        && data.type == existing.type
        && data.referenceId == existing.referenceId
        && data.createdAt == existing.createdAt;
    }

    function sameStockAlertReadScope(data, existing) {
      return data.userId == existing.userId
        && data.alertId == existing.alertId
        && data.branchId == existing.branchId
        && data.productId == existing.productId;
    }

    function canReadTransferAudit(entityId) {
      return exists(/databases/$(database)/documents/transfers/$(entityId))
        && (
          isAdmin()
          || canReadBranch(get(/databases/$(database)/documents/transfers/$(entityId)).data.fromBranchId)
          || canReadBranch(get(/databases/$(database)/documents/transfers/$(entityId)).data.toBranchId)
        );
    }

    function canReadReservationAudit(entityId) {
      return exists(/databases/$(database)/documents/reservations/$(entityId))
        && canReadReservation(
          get(/databases/$(database)/documents/reservations/$(entityId)).data
        );
    }

    function canReadSaleAudit(entityId) {
      return exists(/databases/$(database)/documents/sales/$(entityId))
        && canReadSale(get(/databases/$(database)/documents/sales/$(entityId)).data);
    }

    function canReadAuditLog(data) {
      return isAdmin()
        || (
          data.entityType == 'transfer'
          && canReadTransferAudit(data.entityId)
        )
        || (
          data.entityType == 'reservation'
          && canReadReservationAudit(data.entityId)
        )
        || (
          data.entityType == 'sale'
          && canReadSaleAudit(data.entityId)
        );
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.branchId == resource.data.branchId
          && request.resource.data.isActive == resource.data.isActive
          && request.resource.data.email == resource.data.email);
      allow delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if hasUserProfile();
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if hasUserProfile();
      allow create, update, delete: if isAdmin();
    }

    match /inventories/{inventoryId} {
      allow read: if canReadInventory(resource.data.branchId);
      allow create: if signedIn()
        && validInventoryDerivedFields(request.resource.data)
        && (
          canManageInventory(request.resource.data.branchId)
          || canCreateIncomingTransferInventory(request.resource.data)
        );
      allow update: if signedIn()
        && validInventoryDerivedFields(request.resource.data)
        && request.resource.data.branchId == resource.data.branchId
        && request.resource.data.productId == resource.data.productId
        && (
          canManageInventory(request.resource.data.branchId)
          || canRecordIncomingTransferInventory(request.resource.data, resource.data)
          || canReceiveIncomingTransferInventory(request.resource.data, resource.data)
          || canRegisterSaleInventory(request.resource.data, resource.data)
        );
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if canReadSale(resource.data);
      allow create: if hasUserProfile()
        && request.resource.data.sellerId == request.auth.uid
        && canRegisterSale(request.resource.data.branchId)
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.unitPrice is number
        && request.resource.data.unitPrice > 0
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0;
      allow update, delete: if isAdmin();
    }

    match /transfers/{transferId} {
      allow read: if isAdmin()
        || canReadBranch(resource.data.fromBranchId)
        || canReadBranch(resource.data.toBranchId);
      allow create: if hasUserProfile()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && canRequestTransfer(request.resource.data.toBranchId)
        && request.resource.data.fromBranchId != request.resource.data.toBranchId;
      allow update: if hasUserProfile()
        && sameTransferScope(request.resource.data, resource.data)
        && (
          isAdmin()
          || (
            resource.data.status == 'pending'
            && request.resource.data.status == 'approved'
            && request.resource.data.approvedBy == request.auth.uid
            && canApproveTransfer(resource.data.fromBranchId)
          )
          || (
            resource.data.status == 'pending'
            && request.resource.data.status == 'rejected'
            && request.resource.data.rejectedBy == request.auth.uid
            && request.resource.data.reviewComment is string
            && request.resource.data.reviewComment != ''
            && canApproveTransfer(resource.data.fromBranchId)
          )
          || (
            resource.data.status == 'approved'
            && request.resource.data.status == 'in_transit'
            && canDispatchTransfer(resource.data.fromBranchId)
          )
          || (
            resource.data.status == 'in_transit'
            && request.resource.data.status == 'received'
            && canReceiveTransfer(resource.data.toBranchId)
          )
        );
      allow delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if canReadReservation(resource.data);
      allow create: if hasUserProfile()
        && request.resource.data.reservedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && (isAdmin() || isSeller() || isSupervisor());
      allow update: if hasUserProfile()
        && sameReservationScope(request.resource.data, resource.data)
        && (
          isAdmin()
          || (
            resource.data.status == 'pending'
            && request.resource.data.status == 'active'
            && request.resource.data.approvedBy == request.auth.uid
            && canApproveReservation(resource.data.branchId)
          )
          || (
            resource.data.status == 'pending'
            && request.resource.data.status == 'rejected'
            && request.resource.data.rejectedBy == request.auth.uid
            && request.resource.data.reviewComment is string
            && request.resource.data.reviewComment != ''
            && canApproveReservation(resource.data.branchId)
          )
          || (
            resource.data.status == 'active'
            && (
              request.resource.data.status == 'completed'
              || request.resource.data.status == 'cancelled'
              || request.resource.data.status == 'expired'
            )
            && canUpdateReservation(resource.data)
          )
        );
      allow delete: if isAdmin();
    }

    match /sync_logs/{syncId} {
      allow read: if signedIn();
      allow create: if isAdmin() || canCreateOwnSuccessfulSyncLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /stock_alert_reads/{readId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if hasUserProfile()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && sameStockAlertReadScope(request.resource.data, resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if hasUserProfile();
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.isRead == true
        && sameNotificationScope(request.resource.data, resource.data);
      allow delete: if isAdmin();
    }

    match /audit_logs/{auditId} {
      allow read: if canReadAuditLog(resource.data);
      allow create: if hasUserProfile()
        && request.resource.data.actorUserId == request.auth.uid
        && request.resource.data.actorRole == currentUser().role;
      allow update, delete: if isAdmin();
    }

    match /search_history/{historyId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if signedIn()
        && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /search_filters/{filterId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if signedIn()
        && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /request_logs/{requestId} {
      allow read: if isAdmin();
      allow create: if hasUserProfile()
        && request.resource.data.actorUserId == request.auth.uid
        && request.resource.data.actorRole == currentUser().role;
      allow update, delete: if isAdmin();
    }
  }
}
